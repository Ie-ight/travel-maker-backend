# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files with UTF-8 encoding
*.py text encoding=utf-8
*.md text encoding=utf-8
*.yml text encoding=utf-8
*.yaml text encoding=utf-8
*.json text encoding=utf-8
*.txt text encoding=utf-8
*.sh text eol=lf encoding=utf-8
*.env text encoding=utf-8
.env* text encoding=utf-8

# Declare files that will always have CRLF line endings on checkout
*.bat text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
